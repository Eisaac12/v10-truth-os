# ============================================================
# SOUL AI TRADE AGENT — Environment Configuration Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# ============================================================

# === Anthropic API ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === Telegram Signal Bot ===
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Negative number for groups/channels (e.g. -1001234567890)
TELEGRAM_CHANNEL_ID=-100your_channel_id_here

# === Notion Journal Sync ===
# From: https://www.notion.so/profile/integrations
NOTION_TOKEN=secret_your_notion_integration_token
NOTION_DATABASE_ID=your_notion_database_id_here

# === Account Risk Settings ===
ACCOUNT_SIZE_USD=10000
MAX_RISK_PCT=1.0
DAILY_LOSS_LIMIT_PCT=3.0

# === Execution Mode ===
# "dry_run" on Linux (default) — simulates orders, never touches real money
# "live" on Windows with MT5 installed — places real orders
EXECUTION_MODE=dry_run

# === MetaTrader 5 (Windows only — leave blank on Linux) ===
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# === Scheduling ===
AGENT_TIMEZONE=UTC
