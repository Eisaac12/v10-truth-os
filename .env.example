# ── Claude / Anthropic ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_api_key_here

# ── Notion (optional — injects live workspace context) ─────────────────────
NOTION_API_KEY=your_notion_integration_token
NOTION_PAGE_ID=your_notion_page_id

# ── Telegram bot (optional — enables mobile channel) ──────────────────────
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Comma-separated chat IDs allowed to use the bot (leave empty = open access)
TELEGRAM_ALLOWED_CHAT_IDS=your_telegram_chat_id

# ── Database ───────────────────────────────────────────────────────────────
# Path to SQLite file (auto-created). Default: ./data/truthos.db
DATABASE_PATH=./data/truthos.db

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3001
