# ─── Core AI ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ─── Stripe (payment gate + revenue intel) ────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_ID_CREATOR=price_...        # $29/mo Creator tier
STRIPE_PRICE_ID_VISIONARY=price_...      # $99/mo Visionary tier
STRIPE_PRICE_ID_EMPIRE=price_...         # $299/mo Empire tier
STRIPE_WEBHOOK_SECRET=whsec_...          # optional: for webhook validation

# ─── Twitter / X (Broadcast + Outreach agents) ────────────────────────────────
# Create a Twitter Developer App at developer.twitter.com
# Requires: Read + Write + Direct Messages permissions
TWITTER_API_KEY=...
TWITTER_API_SECRET=...
TWITTER_ACCESS_TOKEN=...
TWITTER_ACCESS_SECRET=...
TWITTER_APP_URL=https://your-app.vercel.app

# ─── Email (Campaign agent) ───────────────────────────────────────────────────
# Use EITHER Resend (recommended) OR SendGrid — not both
RESEND_API_KEY=re_...                    # resend.com
# SENDGRID_API_KEY=SG....               # sendgrid.com (alternative)
EMAIL_FROM=truth@yourdomain.com
EMAIL_FROM_NAME=Truth Weaver
# Comma-separated list of subscriber emails (or use the in-app subscriber form)
SUBSCRIBER_LIST=email1@example.com,email2@example.com

# ─── Gumroad (Product agent) ──────────────────────────────────────────────────
# Get your access token at app.gumroad.com/settings/advanced
GUMROAD_ACCESS_TOKEN=...

# ─── Matrix Scheduler ─────────────────────────────────────────────────────────
MATRIX_TIMEZONE=America/New_York         # scheduler timezone
OUTREACH_DAILY_LIMIT=15                  # max DMs per day (Twitter ToS safe)
